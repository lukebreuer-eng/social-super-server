# ===========================================
# Social Engine - Environment Variables
# ===========================================

# Server
PORT=3001
NODE_ENV=production

# Directus
DIRECTUS_URL=https://social.ipaudio.nl
DIRECTUS_TOKEN=your_directus_static_token_here

# Redis (internal Coolify network)
REDIS_URL=redis://default:password@redis-hostname:6379

# MinIO (internal Coolify network)
MINIO_ENDPOINT=minio-hostname
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123secure
MINIO_BUCKET=social-super-server
MINIO_USE_SSL=false

# AI - Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Email - Resend
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@ipaudio.nl
NOTIFICATION_EMAIL=your_email@example.com

# Social Platforms (filled in after developer account approval)
# Meta (Facebook + Instagram)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://api.ipaudio.nl/oauth/meta/callback

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://api.ipaudio.nl/oauth/linkedin/callback

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://api.ipaudio.nl/oauth/tiktok/callback

# Logging
LOG_LEVEL=info
